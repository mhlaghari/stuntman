#!/usr/bin/env bash
# stuntman scaffold — set up the project-memory system.
#
# Idempotently, and without clobbering anything:
#   - writes a contract block into CLAUDE.md (creates it if absent): a
#     "read this first" list + a "before you stop" process contract,
#   - creates HANDOFF.md (the session baton) and STATUS.md (the status board),
#     each only if it doesn't already exist.
#
# CLAUDE.md auto-loads every session, so the contract is always in context:
# each session reads HANDOFF.md / STATUS.md first and rewrites them before
# stopping. Resume any time with /handoff (or "execute handoff").
#
# Usage: scaffold [project_dir]    (default: current directory)
set -e

DIR="${1:-$PWD}"
CLAUDE_MD="$DIR/CLAUDE.md"
HANDOFF_MD="$DIR/HANDOFF.md"
STATUS_MD="$DIR/STATUS.md"
START="<!-- stuntman:scaffold:start -->"
# also recognize the pre-0.5 marker so re-running never double-adds the block
OLD_START="<!-- stuntman:handoff:start -->"

# Emitted via a function (quoted heredoc) so backticks in the body are literal.
emit_block() {
cat <<'EOF'
<!-- stuntman:scaffold:start -->
## Project memory protocol

**Read this first — start of every session** (or just run `/handoff`):
1. `HANDOFF.md` — what the last session changed, what's next, and the gotchas.
   Assume you have zero memory of prior sessions; this is your memory of them.
2. `STATUS.md` — the running status board: what's built, in progress, and planned.
3. `README.md` — what the project is and how to run it.
4. Any doc those reference (specs, design notes) before building in that area.

**Before you stop — end of every session:**
- Update `HANDOFF.md`: what changed, what's next, and any gotcha that cost time.
  Write it for someone with zero memory of this session.
- Update `STATUS.md`: refresh the board to match reality.
- Update `README.md` if the project's surface changed (features, install, usage).
- Never commit without explicit user authorization.

A task isn't "done" until `HANDOFF.md` and `STATUS.md` reflect it (and `README.md`, if it changed).
<!-- stuntman:scaffold:end -->
EOF
}

# 1. CLAUDE.md contract — idempotent, append-only, never rewrites existing content
if [ -f "$CLAUDE_MD" ] && { grep -qF "$START" "$CLAUDE_MD" || grep -qF "$OLD_START" "$CLAUDE_MD"; }; then
  echo "• CLAUDE.md already has the scaffold contract — left as-is"
elif [ -f "$CLAUDE_MD" ]; then
  { printf '\n'; emit_block; } >> "$CLAUDE_MD"
  echo "• appended scaffold contract to existing CLAUDE.md"
else
  { printf '# CLAUDE.md\n\n'; emit_block; } > "$CLAUDE_MD"
  echo "• created CLAUDE.md with the scaffold contract"
fi

# 2. HANDOFF.md — the session baton (created only if missing)
if [ -f "$HANDOFF_MD" ]; then
  echo "• HANDOFF.md already exists — left untouched"
else
  cat > "$HANDOFF_MD" <<'EOF'
# HANDOFF

> The session baton. The current agent updates this before stopping; the next
> agent reads it first. Write for a reader with zero memory of this session.

## What changed this session
_What you did, concretely._

## Next step
_The single most important thing to do next, then the rest in priority order._

## Gotchas
_Anything that cost time — traps, non-obvious constraints._

## Last updated
_Session date + one-line summary._
EOF
  echo "• created HANDOFF.md"
fi

# 3. STATUS.md — the project status board (created only if missing)
if [ -f "$STATUS_MD" ]; then
  echo "• STATUS.md already exists — left untouched"
else
  cat > "$STATUS_MD" <<'EOF'
# STATUS

> Where the project stands right now. Refreshed each session alongside HANDOFF.md.

## Built
_Shipped and working._

## In progress
_Being worked on now._

## Planned
_Next up, not started._

## Last updated
_Session date._
EOF
  echo "• created STATUS.md"
fi

echo "✓ project-memory system scaffolded in $DIR"
echo "  next session: run /handoff (or say \"execute handoff\") to resume."

#!/usr/bin/env bash
# stuntman scaffold — set up the project-memory system (living documents).
#
# Idempotently, and without clobbering anything, it:
#   - writes a contract into CLAUDE.md (a read-first list + before-you-stop rules),
#   - creates the living docs it references, each only if it doesn't exist:
#       HANDOFF.md    the session baton  (what changed, next step, gotchas)
#       STATUS.md     the board          (built / in progress / planned)
#       SPEC.md       the contract       (what it is, principles, where it's going)
#       STRATEGY.md   the honest why     (assessment, direction)
#
# CLAUDE.md auto-loads every session, so the contract is always in context: each
# session reads the docs first and keeps them current. Resume with /handoff.
#
# Usage: scaffold [project_dir]    (default: current directory)
set -e

DIR="${1:-$PWD}"
CLAUDE_MD="$DIR/CLAUDE.md"
START="<!-- stuntman:scaffold:start -->"
OLD_START="<!-- stuntman:handoff:start -->"   # pre-0.5 marker

# CLAUDE.md contract — quoted heredoc so backticks in the body stay literal.
emit_block() {
cat <<'EOF'
<!-- stuntman:scaffold:start -->
## Project memory protocol

These are **living documents** — read them first, keep them current.

**Read this first — start of every session** (or just run `/handoff`):
1. `HANDOFF.md` — the session baton: what the last session changed, the next step, gotchas. Assume zero memory of prior sessions.
2. `STATUS.md` — the board: built / in progress / planned.
3. `SPEC.md` — the contract: what this is, the load-bearing principles, where it's going. Build to it.
4. `STRATEGY.md` — the honest why / direction. Read before any big call.
5. `README.md` — what the project is and how to run it.

**Before you stop — end of every session:**
- Always update `HANDOFF.md` (what changed, next step, gotchas) and `STATUS.md` (refresh the board).
- Update `SPEC.md`, `STRATEGY.md`, or `README.md` whenever the change touched what they cover — and add a dated changelog line.
- Never commit without explicit user authorization.

A task isn't "done" until the docs its change touched reflect it.
<!-- stuntman:scaffold:end -->
EOF
}

# write stdin to <path> only if it doesn't already exist (else consume + skip)
make() {
  local path="$1" label="$2"
  if [ -f "$path" ]; then
    cat >/dev/null
    echo "• $label already exists — left untouched"
  else
    cat > "$path"
    echo "• created $label"
  fi
}

# 1. CLAUDE.md contract — idempotent, append-only, never rewrites existing content
if [ -f "$CLAUDE_MD" ] && { grep -qF "$START" "$CLAUDE_MD" || grep -qF "$OLD_START" "$CLAUDE_MD"; }; then
  echo "• CLAUDE.md already has the scaffold contract — left as-is"
elif [ -f "$CLAUDE_MD" ]; then
  { printf '\n'; emit_block; } >> "$CLAUDE_MD"
  echo "• appended scaffold contract to existing CLAUDE.md"
else
  { printf '# CLAUDE.md\n\n'; emit_block; } > "$CLAUDE_MD"
  echo "• created CLAUDE.md with the scaffold contract"
fi

# 2. HANDOFF.md — the session baton
make "$DIR/HANDOFF.md" "HANDOFF.md" <<'EOF'
# HANDOFF

_The session baton — a **living doc**. The current agent updates it before
stopping; the next reads it first. Write for a reader with zero memory of this
session._

## What changed this session
_What you did, concretely._

## Next step
_The single most important next action, then the rest in priority order._

## Gotchas
_Anything that cost time — traps, non-obvious constraints._

## Last updated
_Session date + one-line summary._
EOF

# 3. STATUS.md — the board
make "$DIR/STATUS.md" "STATUS.md" <<'EOF'
# STATUS

_The board — a **living doc**. Where the project stands right now; refresh it
every session._

## Built
_Shipped and working._

## In progress
_Being worked on now._

## Planned
_Next up, not started._

## Blockers
_Anything stuck, and on what._

## Last updated
_Session date._
EOF

# 4. SPEC.md — the contract
make "$DIR/SPEC.md" "SPEC.md" <<'EOF'
# SPEC

_The product contract — a **living doc**. What this is and where it's going
(`CLAUDE.md` covers the current code; this covers the destination). Every session
reads this first; keep it current._

## Vision
_One paragraph: what this is, and the end state you're building toward._

## Principles (load-bearing — do not violate)
_The non-negotiables, numbered — the rules a session must never break._

## Scope
- **In:** _what this is._
- **Out (for now):** _what's deliberately deferred._

## Open decisions
_Unresolved choices — each with the options and the current lean._

## Changelog
- _(date)_ — created.
EOF

# 5. STRATEGY.md — the honest why
make "$DIR/STRATEGY.md" "STRATEGY.md" <<'EOF'
# STRATEGY

_A **living doc** — the honest version on purpose, not a pitch. Maintain it;
revisit before any big direction call._

## Bottom line (read this first)
_The 3–5 sharpest truths about where this stands right now._

## Honest assessment
_What's working, what isn't, and the real risks — no spin._

## Direction
_Where to focus and why — the wedge, the bet, the sequencing._

## Open questions / to revisit
_The calls you're not ready to make yet._

## Changelog
- _(date)_ — created.
EOF

echo "✓ project-memory system scaffolded in $DIR"
echo "  populate the stubs from the project, then resume any time with /handoff."

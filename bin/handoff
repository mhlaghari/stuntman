#!/usr/bin/env bash
# stuntman handoff — scaffold the session-handoff loop into a project.
#
# Idempotently, and without clobbering anything:
#   - inserts a marked handoff block into CLAUDE.md (creates the file if absent),
#   - drops a HANDOFF.md stub only if one doesn't already exist.
#
# So every future Claude session in this project reads HANDOFF.md first and
# rewrites it before stopping — "execute handoff" resumes with zero re-explaining.
# Pairs with /delegate (saves cost) and /relay (survives the rate limit): this
# one survives the context boundary.
#
# Usage: handoff [project_dir]    (default: current directory)
set -e

DIR="${1:-$PWD}"
CLAUDE_MD="$DIR/CLAUDE.md"
HANDOFF_MD="$DIR/HANDOFF.md"
START="<!-- stuntman:handoff:start -->"

# Emitted via a function (quoted heredoc) so backticks in the body are literal.
emit_block() {
cat <<'EOF'
<!-- stuntman:handoff:start -->
## Session handoff protocol

**Read this first — start of every session:**
1. Read `HANDOFF.md` (repo root) — current state, what works, what's next, gotchas.
   Assume you have zero memory of prior sessions; `HANDOFF.md` is your memory.

**Before you stop — end of every session:**
- Update `HANDOFF.md` for the next session: what changed, what works, what's next,
  and any gotcha that cost you time. Write it for someone with zero memory of this session.
- Never commit without explicit user authorization.

A task isn't "done" until `HANDOFF.md` reflects it. To resume, the user just says "execute handoff".
<!-- stuntman:handoff:end -->
EOF
}

# 1. CLAUDE.md block — idempotent, append-only, never rewrites existing content
if [ -f "$CLAUDE_MD" ] && grep -qF "$START" "$CLAUDE_MD"; then
  echo "• CLAUDE.md already has the handoff block — left as-is"
elif [ -f "$CLAUDE_MD" ]; then
  { printf '\n'; emit_block; } >> "$CLAUDE_MD"
  echo "• appended handoff block to existing CLAUDE.md"
else
  { printf '# CLAUDE.md\n\n'; emit_block; } > "$CLAUDE_MD"
  echo "• created CLAUDE.md with the handoff block"
fi

# 2. HANDOFF.md stub — created only if missing, never clobbered
if [ -f "$HANDOFF_MD" ]; then
  echo "• HANDOFF.md already exists — left untouched"
else
  cat > "$HANDOFF_MD" <<'EOF'
# HANDOFF

> The living memory of this project across sessions. The agent updates this
> before stopping; the next agent reads it first. Write for a reader with zero
> prior context.

## Current state
_What works right now._

## What's next
_Immediate next steps, in priority order._

## Gotchas
_Anything that cost time — traps, non-obvious constraints._

## Last updated
_Session date + one-line summary._
EOF
  echo "• created HANDOFF.md stub"
fi

echo "✓ handoff loop scaffolded in $DIR"
